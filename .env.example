# Guardian Bot - Environment Variables
# Copy this to .env for local development
# On Railway/Render: set these in the dashboard (never commit real values!)

# Your Telegram bot token from @BotFather
TELEGRAM_TOKEN=your_bot_token_here

# Your personal Telegram chat ID (get it from @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id_here

# Where to store the data file (default: health_credits.json in project root)
# DATA_FILE=health_credits.json
